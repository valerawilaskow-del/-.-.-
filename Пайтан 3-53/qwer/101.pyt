dct = {
	'x': 1,
	'y': 2,
	'z': 3
}
res = dct.keys()
print(res)

dct = {
	1: 'x',
	2: 'y',
	3: 'z',
	4: 'w'
}
res = dct.keys()
print(res)

dct = {
	'x': 1,
	'y': 2,
	'z': 3
}
res = list(dct.keys())
print(res)

dct = {
	2: 'ab',
	4: 'cd',
	6: 'ef'
}
res = dct.keys()
print(res)

dct = {1: 'x', 2: 'y', 3: 'z', 4: 'w'}
res = list(reversed(dct.keys()))
print(res)  

